        <arguments>
          <argument>
            <kind>1</kind>
            <string>model = d3d_model_create();
d3d_model_primitive_begin(model, pr_trianglelist);
modeloutline = d3d_model_create();
d3d_model_primitive_begin(modeloutline, pr_linestrip);

for (var i=0; i&lt;facecount; i++)
{
    var vertex;
    vertex[0] = faces[i, 0]-1;
    vertex[1] = faces[i, 1]-1;
    vertex[2] = faces[i, 2]-1;
    
    d3d_model_vertex_colour(model, verts[vertex[0], 0], verts[vertex[0], 1], verts[vertex[0], 2], c_white, 1);
    d3d_model_vertex_colour(model, verts[vertex[1], 0], verts[vertex[1], 1], verts[vertex[1], 2], c_white, 1);
    d3d_model_vertex_colour(model, verts[vertex[2], 0], verts[vertex[2], 1], verts[vertex[2], 2], c_white, 1);
    
    d3d_model_vertex_colour(modeloutline, verts[vertex[0], 0], verts[vertex[0], 1], verts[vertex[0], 2], c_black, 1);
    d3d_model_vertex_colour(modeloutline, verts[vertex[1], 0], verts[vertex[1], 1], verts[vertex[1], 2], c_black, 1);
    d3d_model_vertex_colour(modeloutline, verts[vertex[2], 0], verts[vertex[2], 1], verts[vertex[2], 2], c_black, 1);
}

d3d_model_primitive_end(model);
d3d_model_primitive_end(modeloutline);
</string>
