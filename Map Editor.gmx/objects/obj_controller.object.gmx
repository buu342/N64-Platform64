      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>menubar[0] = noone;
menubar_focused = false;
menubar_active_menu = -1;
menubar_selected_elem = -1;

menubar_submenunext = 0;

lastmousex = 0
lastmousey = 0

var i=0;


// Files Submenu

var shtcut_new; shtcut_new[0] = vk_control; shtcut_new[1] = ord("N"); 
var shtcut_load; shtcut_load[0] = vk_control; shtcut_load[1] = ord("L"); 
var shtcut_save; shtcut_save[0] = vk_control; shtcut_save[1] = ord("S"); 
var shtcut_comp; shtcut_comp[0] = vk_control; shtcut_comp[1] = ord("C"); 
var shtcut_importmapmesh; shtcut_importmapmesh[0] = vk_control; shtcut_importmapmesh[1] = vk_alt; shtcut_importmapmesh[2] = ord("M"); 
var shtcut_importmapcol; shtcut_importmapcol[0] = vk_control; shtcut_importmapcol[1] = vk_alt; shtcut_importmapcol[2] = ord("C"); 
var shtcut_exit; shtcut_exit[0] = vk_alt; shtcut_exit[1] = vk_f4; 

var filesub;
filesub[i++] = scr_submenu_create("New", scr_func_new, shtcut_new, 0);
filesub[i++] = scr_submenu_create("Load", scr_func_load, shtcut_load, 1);
filesub[i++] = scr_submenu_create("Save", scr_func_save, shtcut_save, 2);
filesub[i++] = scr_submenu_create(-1, -1, -1, -1);
filesub[i++] = scr_submenu_create("Import Map Mesh", scr_func_import_mapmesh, shtcut_importmapmesh, 5);
filesub[i++] = scr_submenu_create("Import Map Collision", scr_func_import_mapcol, shtcut_importmapcol, 6);
filesub[i++] = scr_submenu_create(-1, -1, -1, -1);
filesub[i++] = scr_submenu_create("Compile", scr_func_comp, shtcut_comp, -1);
filesub[i++] = scr_submenu_create(-1, -1, -1, -1);
filesub[i++] = scr_submenu_create("Exit", scr_func_exit, shtcut_exit, 3);


// View Submenu

var viewsub; i=0;
viewsub[i++] = scr_submenu_create("Toggle Axis", scr_func_toggleaxis, -1, "settings_drawAxis");
viewsub[i++] = scr_submenu_create("Toggle Floor", scr_func_togglefloor, -1, "settings_drawFloor");
viewsub[i++] = scr_submenu_create(-1, -1, -1, -1);
viewsub[i++] = scr_submenu_create("Toggle Map Mesh", scr_func_togglemapmesh, -1, "settings_drawMap");
viewsub[i++] = scr_submenu_create("Toggle Map Collision", scr_func_togglemapcol, -1, "settings_drawCollision");

// Game Submenu

var gamesub; i=0;
var shtcut_game; shtcut_game[0] = vk_home;
gamesub[i++] = scr_submenu_create("Toggle Game", scr_func_togglegame, shtcut_game, "game_running");


// Help Submenu

var helpsub; i=0;
helpsub[i++] = scr_submenu_create("Help", -1, -1, 4);


// Menubar

enum menubar_e {
    file = 0,
    view = 1,
    game = 2,
    help = 3,
}

menubar[@menubar_e.file] = scr_menu_create("File", filesub, ord('F'))
menubar[@menubar_e.view] = scr_menu_create("View", viewsub, ord('V'))
menubar[@menubar_e.game] = scr_menu_create("Game", gamesub, ord('G'))
menubar[@menubar_e.help] = scr_menu_create("Help", helpsub, ord('H'))
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>605</id>
        <kind>0</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>Mouselook</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if mouse_check_button(mb_right)
{
    if mouse_check_button_pressed(mb_right)
    {
        menubar_focused = false
        menubar_active_elem = -1
        menubar_active_menu = -1
        window_set_cursor(cr_none)
        display_mouse_set(display_get_width()/2, display_get_height()/2);
    }
    
    //get change
    change_x = (display_mouse_get_x()-display_get_width()/2)
    change_y = (display_mouse_get_y()-display_get_height()/2)
    
    //move camera
    direction-=change_x/12
    zdirection+=change_y/12
    
    //limit z
    if zdirection &lt; -89.99
        zdirection = -89.99
    else if zdirection &gt; 89.99
        zdirection = 89.99
        
    //center mouse
    display_mouse_set(display_get_width()/2, display_get_height()/2);
}
else if mouse_check_button_released(mb_right)
{
    window_set_cursor(cr_default)
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>605</id>
        <kind>0</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>Movement</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>var myspeed = 10

if mouse_check_button(mb_right)
{
    if keyboard_check(ord('W'))
    {
        x += lengthdir_x(myspeed, direction)*(1-abs(zdirection/90));
        y += lengthdir_y(myspeed, direction)*(1-abs(zdirection/90))
        z += myspeed*(-zdirection/90);
    }
    
    if keyboard_check(ord('D'))
    {
        x += lengthdir_x(myspeed, direction-90);
        y += lengthdir_y(myspeed, direction-90);
    }
    
    if keyboard_check(ord('A'))
    {
        x += lengthdir_x(myspeed, direction+90);
        y += lengthdir_y(myspeed, direction+90);
    }
    
    if keyboard_check(ord('S'))
    {
        x += lengthdir_x(-myspeed, direction)*(1-abs(zdirection/90));
        y += lengthdir_y(-myspeed, direction)*(1-abs(zdirection/90))
        z += myspeed*(zdirection/90);
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>605</id>
        <kind>0</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>Draw Crosshair</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_sprite(spr_crosshair, 0, view_wview[0]/2, view_hview[0]/2)
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>605</id>
        <kind>0</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>Draw and handle the menu bar</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>var mx = display_mouse_get_x() - window_get_x();
var my = display_mouse_get_y() - window_get_y();


// Draw the menu bar

draw_set_color(c_gray)
draw_rectangle(0, 0, view_wview[0], MENUBAR_HEIGHT, false)
if (mx &gt;= 0 &amp;&amp; mx &lt; view_wview[0] &amp;&amp; my &gt;= 0 &amp;&amp; my &lt;= MENUBAR_HEIGHT)
{
    menubar_focused = true
    menubar_submenunext = 1
}


// Draw the second menu bar

draw_set_color(c_gray)
draw_rectangle(0, MENUBAR_HEIGHT, view_wview[0], MENUBAR_HEIGHT+MENUBAR2_HEIGHT, false)
draw_set_color(c_dkgray)
draw_line(0, MENUBAR_HEIGHT, view_wview[0], MENUBAR_HEIGHT)
draw_set_color(c_white)


// Draw the menu bar's menus

draw_set_color(c_black)
var i;
var mbarsize = array_length_1d(menubar);
var spacing = MENUBAR_SPACING;
var lastx = spacing;
for (i=0; i&lt;mbarsize; i+=1)
{
    var menu = menubar[i];
    var str = menu[menu_e.name];
    var strwid = string_width(str);
    var xdata = scr_menubar_elemxdata(menubar, i);
    
    // Handle mouse over menu
    if (mx &gt;= xdata[0] &amp;&amp; mx &lt; xdata[1] &amp;&amp; my &gt;= 0 &amp;&amp; my &lt;= MENUBAR_HEIGHT)
    {
        // Handle mousing over other menus/selecting menus
        if ((menubar_active_menu != -1 &amp;&amp; menubar_active_menu != i &amp;&amp; (mx != lastmousex || my != lastmousey)) || mouse_check_button_pressed(mb_left))
        {
            menubar_active_menu = i
            menubar_submenunext = 1
        }
        
        // Draw blue on selected menu
        if (menubar_active_menu == -1)
        {
            draw_set_color(c_blue)
            draw_rectangle(lastx-spacing, 0, lastx + strwid + spacing, MENUBAR_HEIGHT, false)
            draw_set_color(c_black)
        }
    }
    
    // Draw active menu
    if (menubar_active_menu == i)
    {
        draw_set_color(c_ltgray)
        draw_rectangle(lastx-spacing, 0, lastx + strwid + spacing, MENUBAR_HEIGHT, false)
        draw_set_color(c_black)
    }
    
    // Draw box around menu item
    draw_rectangle(lastx-spacing, 0, lastx + strwid + spacing, MENUBAR_HEIGHT, true)
    draw_text(lastx, 0, str)
    lastx += strwid + spacing*2
}


// Draw the submenu

if (menubar_active_menu != -1)
{
    var xpos = scr_menubar_elemxdata(menubar, menubar_active_menu);
    var ypos = MENUBAR_HEIGHT+1
    var submenu_w = 0;
    var submenu_h = 0;
    var menu = menubar[menubar_active_menu];
    var names; names[0] = 0;
    var scripts; scripts[0] = 0;
    var shortcuts; shortcuts[0] = 0;
    var icons; icons[0] = 0;
    var shorttext; shorttext[0] = "";
    var sub = menu[menu_e.submenu];
    
    var numelms = array_length_1d(sub);
    
    // Get all the info about the submenus
    for (i=0; i&lt;numelms; i++)
    {        
        var elem = sub[i];
        names[@i] = elem[submenu_e.name]
        scripts[@i] = elem[submenu_e.script]
        shortcuts[@i] = elem[submenu_e.shortcut]
        icons[@i] = elem[submenu_e.icon]
        shorttext[@i] = scr_shortcut2text(shortcuts[i])
        
        var strwid = string_width(names[i]);
        var strhei = string_height(names[i]);
        var shortwid = string_width(shorttext[i]);
        submenu_h += strhei;
        if (submenu_w &lt; strwid+ELEMENT_SPACING+shortwid)
            submenu_w = strwid+ELEMENT_SPACING+shortwid
    }
    
    // Draw the back of the submenu
    draw_set_color(c_ltgray)
    draw_rectangle(xpos[0], ypos, xpos[0]+submenu_w, ypos+submenu_h, false)
    draw_set_color(c_black)
    draw_rectangle(xpos[0], ypos, xpos[0]+submenu_w, ypos+submenu_h, true)
    
    // Elements
    var moved = false;
    for (i=0; i&lt;numelms; i++)
    {
        var strht = string_height("ABCDEFGHIJKLMNOPQRSTUVWXYZ")
        
        // Handle mouse over element
        if (mx != lastmousex || my != lastmousey)
        {
            if (mx &gt;= xpos[0] &amp;&amp; mx &lt; xpos[0]+submenu_w &amp;&amp; my &gt;= ypos+i*strht &amp;&amp; my &lt; ypos+strht+i*strht)
            {
                menubar_selected_elem = i;
                moved = true;
            }
            else if (i+1 == numelms &amp;&amp; !moved)
            {
                menubar_selected_elem = -1;
            }
        }
        
        // Handle clicking on active element
        if (menubar_selected_elem == i &amp;&amp; names[i] != -1)
        {
            // Draw blue on the highlighted element
            draw_set_color(c_blue)
            draw_rectangle(xpos[0]+1, ypos+i*strht+1, xpos[0]+submenu_w-1, ypos+strht+i*strht-1, false)
            draw_set_color(c_black)
            
            // Handle clicking on the element
            if (scripts[i] != -1 &amp;&amp; (mouse_check_button_released(mb_left) || keyboard_check_pressed(vk_enter)))
            {
                menubar_focused = false
                menubar_active_menu = -1
                menubar_selected_elem = -1
                script_execute(scripts[i])
            }
        }
        
        // Draw each element of the submenu
        if (names[i] != -1)
        {
            if (icons[i] != -1)
            {
                if (is_string(icons[i]))
                {
                    if (variable_instance_get(self.id, icons[i]))
                        draw_sprite(spr_icons, 7, xpos[0]+3, ypos+i*strht+2);
                }
                else
                    draw_sprite(spr_icons, icons[i], xpos[0]+3, ypos+i*strht+2);
            }
            draw_set_halign(fa_left)
            draw_text(xpos[0]+8+12, ypos+i*strht, names[i])
            draw_set_halign(fa_right)
            draw_text(xpos[0]+submenu_w-8, ypos+i*strht, shorttext[i])
            draw_set_halign(fa_left)
        }
        else
        {
            draw_set_color(c_dkgray);
            draw_line(xpos[0]+4+16, ypos+i*strht+strht/2, xpos[0]+submenu_w-4, ypos+i*strht+strht/2);
            draw_set_color(c_black);
        }
    }
    
    // Draw a line for the icons
    draw_set_color(c_dkgray)
    draw_line(xpos[0]+17, ypos+4, xpos[0]+17, ypos+submenu_h-4);
    
    // Handle arrow keys on active menu
    if (keyboard_check_pressed(vk_up))
    {
        if (menubar_selected_elem &lt;= 0)
            menubar_selected_elem = numelms-1;
        else
            menubar_selected_elem = (menubar_selected_elem-1)%numelms;
        if (names[menubar_selected_elem] == -1)
            menubar_selected_elem--;
    }
    if (keyboard_check_pressed(vk_down))  
    {
        menubar_selected_elem = (menubar_selected_elem+1)%numelms;
        if (names[menubar_selected_elem] == -1)
            menubar_selected_elem++;
    }  
    
    // Handle submenu clicking
    if (mouse_check_button_pressed(mb_left) &amp;&amp; menubar_submenunext == 0)
    {
        if (!(mx &gt;= xpos[0] &amp;&amp; mx &lt; xpos[0]+submenu_w &amp;&amp; my &gt;= ypos &amp;&amp; my &lt;= ypos+submenu_h))
        {
            menubar_focused = false
            menubar_active_menu = -1
        }
    }
}
draw_set_color(c_white)

if (menubar_submenunext &gt; 0)
    menubar_submenunext--
   
        
// Handle arrow keys on active menu

if (menubar_active_menu != -1 &amp;&amp; keyboard_check_pressed(vk_left))
{
    if (menubar_active_menu == 0)
        menubar_active_menu = mbarsize-1;
    else
        menubar_active_menu = (menubar_active_menu-1)%mbarsize;
    menubar_selected_elem = -1;
}
if (menubar_active_menu != -1 &amp;&amp; keyboard_check_pressed(vk_right))  
{
    menubar_active_menu = (menubar_active_menu+1)%mbarsize;
    menubar_selected_elem = -1;
}
    

// Alt shortcut for menubar items

if (keyboard_check(vk_alt) &amp;&amp; !keyboard_check(vk_control))
{
    for (i=0; i&lt;mbarsize; i++)
    {
        var menu = menubar[i];
        var key = menu[menu_e.shortcut];
        if keyboard_check_pressed(key)
        {
            if menubar_active_menu != i
            {
                menubar_focused = true
                menubar_active_menu = i
            }
            else
            {
                menubar_focused = false
                menubar_active_menu = -1
            }
        }
    }
}


// Handle keyboard shortcuts

for (i=0; i&lt;mbarsize; i+=1)
{
    var menu = menubar[i];
    var sub = menu[menu_e.submenu]
    var size = array_length_1d(sub)
    
    // Get all the info about the submenus
    for (j=0; j&lt;size; j++)
    {        
        var elem = sub[j];
        var short = elem[submenu_e.shortcut];
        var numshort = array_length_1d(short);
        for (k=0; k&lt;numshort; k++)
        {
            if (!keyboard_check(short[k]))
                break;
            if ((numshort == 1 &amp;&amp; keyboard_check_pressed(short[k])) || (numshort != 1 &amp;&amp; k+1==numshort))
            {
                menubar_focused = false
                menubar_active_menu = -1
                script_execute(elem[submenu_e.script])
            }
        }
    }
}

lastmousex = mx
lastmousey = my
</string>
          </argument>
        </arguments>
      </action>
    </event>
