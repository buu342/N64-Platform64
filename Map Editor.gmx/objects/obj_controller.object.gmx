        <arguments>
          <argument>
            <kind>1</kind>
            <string>var mx = display_mouse_get_x() - window_get_x();
var my = display_mouse_get_y() - window_get_y();

if (my &lt;= MENUBAR2_HEIGHT || menubar_focused) 
    exit;

if mouse_check_button_pressed(mb_left)
{
    var pos;
    var dir = screen_toworld(mx, my);
    pos[0] = x;
    pos[1] = y;
    pos[2] = z;
    
    var ray = instance_create(x, y, obj_ray);
    with (ray)
    {
        self.pos = pos;
        self.dir = dir;
        self.dist = obj_controller.z_far;
    }
}
</string>
