            <kind>1</kind>
            <string>// Draw the camera projection

xf = x              //x to look from
yf = y              //y to look from
zf = z              //z to look from

xt = xf+cos(degtorad(direction))         //x to look to (with direction)
yt = yf-sin(degtorad(direction))         //y to look to (with direction)
zt = zf-tan(degtorad(zdirection))        //z to look to (with z direction)

d3d_set_projection_ext(xf, yf, zf, xt, yt, zt, xu, yu, zu, fov, aspect, z_near, z_far)
</string>
