            <kind>1</kind>
            <string>if (settings_drawFloor)
{
    d3d_transform_set_identity();
    
    draw_set_alpha(1)
    draw_set_alpha_test(true)
    d3d_set_culling(false)
    d3d_draw_floor(-room_width/2, -room_height/2, 0, room_width/2, room_height/2, 0, background_get_texture(bac_floor), room_width/64, room_height/64)
    d3d_set_culling(true)
    draw_set_alpha_test(false)
    draw_set_alpha(1)
}

if (settings_drawAxis)
{
    d3d_set_hidden(false)
    d3d_transform_set_identity();
    draw_set_color(c_blue)
    d3d_draw_cone(-2, -2, 26, 2, 2, 32, -1, 1, 1, true, 8)
    d3d_draw_cylinder(-0.5, -0.5, 0, 0.5, 0.5, 26, -1, 1, 1, true, 32)
    draw_set_color(c_white)
    
    d3d_transform_set_identity();
    d3d_transform_add_rotation_y(-90)
    draw_set_color(c_red)
    d3d_draw_cone(-2, -2, 26, 2, 2, 32, -1, 1, 1, true, 8)
    d3d_draw_cylinder(-0.5, -0.5, 0, 0.5, 0.5, 26, -0.1, 0.1, 1, true, 32)
    draw_set_color(c_white)
    
    d3d_transform_set_identity();
    d3d_transform_add_rotation_x(90)
    draw_set_color(c_lime)
    d3d_draw_cone(-2, -2, 26, 2, 2, 32, -1, 1, 1, true, 8)
    d3d_draw_cylinder(-0.5, -0.5, 0, 0.5, 0.5, 26, -1, 1, 1, true, 32)
    draw_set_color(c_white)
    
    d3d_transform_set_identity();
    d3d_set_hidden(true)
}
</string>
