        <arguments>
          <argument>
            <kind>1</kind>
            <string>if instance_exists(obj_ray)
{
    if (object_get_name(object_index) == "obj_mapmesh" &amp;&amp; !obj_controller.settings_drawMap)
        exit;
    if (object_get_name(object_index) == "obj_mapcol" &amp;&amp; !obj_controller.settings_drawCollision)
        exit;    
    
    var triangles;
    triangles[0, 0] = 0;
      
    // TODO: Build this elsewhere PLEASE
    for (var i=0; i&lt;facecount; i++)
    {
        var v1, v2, v3;
        v1 = array_create(3);
        v2 = array_create(3);
        v3 = array_create(3);
        
        v1[@0] = verts[faces[i, 0]-1, 0];
        v1[@1] = verts[faces[i, 0]-1, 1];
        v1[@2] = verts[faces[i, 0]-1, 2];
        v2[@0] = verts[faces[i, 1]-1, 0];
        v2[@1] = verts[faces[i, 1]-1, 1];
        v2[@2] = verts[faces[i, 1]-1, 2];
        v3[@0] = verts[faces[i, 2]-1, 0];
        v3[@1] = verts[faces[i, 2]-1, 1];
        v3[@2] = verts[faces[i, 2]-1, 2];
        
        triangles[@i, 0] = v1;
        triangles[@i, 1] = v2;
        triangles[@i, 2] = v3;
    }
    
    if (ray_tri_intersect(obj_ray.pos, obj_ray.dir, triangles))
    {
        var dist = point_distance_3d(x, y, z, obj_ray.pos[0], obj_ray.pos[1], obj_ray.pos[2]);
        if (obj_ray.closest_distance == -1 || dist &lt; obj_ray.closest_distance)
        {
            obj_ray.closest_distance = dist;
            obj_ray.closest_object = self;
        }
    }
}
</string>
          </argument>
